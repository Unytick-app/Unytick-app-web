# --- NEXTAUTH CONFIG ---
# URL base de la aplicación. 
# En desarrollo: http://localhost:3000
# En producción DEBE ser la URL exacta de tu dominio (ej: https://mi-dominio.com) SIN barra (slash) al final.
NEXTAUTH_URL="http://localhost:3000"

# Secreto usado por NextAuth para encriptar las cookies de sesión.
# En producción, genera uno seguro ejecutando en terminal: openssl rand -base64 32
NEXTAUTH_SECRET="tu_secreto_generado_aqui"

# --- API CONFIG ---
# URL base de tu backend / API para llamadas asíncronas desde el servidor
API_URL="https://tu-api-produccion.com/"

# URL base de tu backend / API expuesta para llamadas desde componentes de cliente
NEXT_PUBLIC_API_URL="https://tu-api-produccion.com/"